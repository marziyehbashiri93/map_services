{
  "options": {
    "paths": {
      "root": "",
      "styles": "styles",
      "fonts": "fonts",
      "sprites": "sprites",
      "mbtiles": "tiles"
    },
    "domains": [
      "localhost:9090",
      "127.0.0.1:9090",
      "localhost:8080",
      "127.0.0.1:8080"
    ],
    "formatOptions": {
      "jpeg": {
        "quality": 80
      },
      "webp": {
        "quality": 90
      }
    },
    "maxScaleFactor": 3,
    "maxSize": 2048,
    "pbfAlias": "pbf",
    "serveAllFonts": true,
    "serveAllStyles": false,
    "serveStaticMaps": true,
    "allowRemoteMarkerIcons": true,
    "tileMargin": 0
  },
  "data": {
    "static_road": {
      "mbtiles": "static_road.mbtile"
    },
    "static_complication": {
      "mbtiles": "static_complication.mbtile"
    },
    "static_admin_division": {
      "mbtiles": "static_admin_division.mbtile"
    },
    "static_landuse": {
      "mbtiles": "static_landuse.mbtile"
    }
  }
}
