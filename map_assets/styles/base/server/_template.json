{
  "glyphs": "__BASE_URL__/fonts/{fontstack}/{range}.pbf",
  "sprite": "__BASE_URL__/sprite/v1/sprite",
  "sources": {
    "osm": {
      "name": "osm layers",
      "type": "vector",
      "tiles": [
        "__BASE_URL__/osm/{z}/{x}/{y}"
      ],
      "scheme": "xyz",
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "Viuna Attribution"
    },
    "custom": {
      "name": "custom layers",
      "type": "vector",
      "tiles": [
        "__BASE_URL__/custom/{z}/{x}/{y}"
      ],
      "scheme": "xyz",
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "Viuna Attribution"
    },
    "terrain": {
      "type": "raster-dem",
      "tiles": [
        "__BASE_URL__/terrain_tiles/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "encoding": "mapbox",
      "maxzoom": 10,
      "minzoom": 4
    }
  }
}
