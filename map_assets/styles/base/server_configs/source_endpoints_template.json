{
  "glyphs": "__BASE_URL__/fonts/{fontstack}/{range}.pbf",
  "sprite": "__BASE_URL__/sprite/v2/sprite",
  "sources": {
    "custom": {
      "name": "custom layers",
      "type": "vector",
      "tiles": [
        "__BASE_URL__/custom/{z}/{x}/{y}"
      ],
      "scheme": "xyz",
      "minzoom": 0,
      "maxzoom": 15,
      "attribution": "Viuna Attribution"
    },
    "terrain": {
      "type": "raster-dem",
      "tiles": [
        "__BASE_URL__/terrain_tiles/{z}/{x}/{y}.webp"
      ],
      "tileSize": 256,
      "encoding": "mapbox",
      "maxzoom": 9,
      "minzoom": 4
    },
    "base": {
      "name": "base layers",
      "type": "vector",
      "tiles": [
        "__BASE_URL__/base/{z}/{x}/{y}"
      ],
      "scheme": "xyz",
      "minzoom": 0,
      "maxzoom": 16,
      "attribution": "Viuna Attribution"
    }
  }
}
