# GraphHopper reverse proxy — do NOT include this file as-is (nginx cannot nest server{}).
#
# Enable routing:
# 1) Add the upstream block below to conf.d/00-upstreams.conf (or a new file loaded before this).
# 2) Paste the location block into the server { } in conf.d/10-gateway-http.conf
#    (e.g. after /styles/legacy/).
#
# Upstream examples:
#   Docker Compose service:     server graphhopper:8989;
#   GraphHopper on host, Nginx in container (Linux):
#     server host.docker.internal:8989;  # plus extra_hosts on nginx service, see Docker docs
#   Bare metal Nginx:             server 127.0.0.1:8989;
#
# --- upstream (place in 00-upstreams.conf) ---
# upstream graphhopper_upstream {
#     server graphhopper:8989;
#     keepalive 8;
# }
#
# --- location (paste inside server { } in 10-gateway-http.conf) ---
# location /graphhopper/ {
#     rewrite ^/graphhopper(/.*)$ $1 break;
#     proxy_pass http://graphhopper_upstream;
#     proxy_http_version 1.1;
#     proxy_set_header Upgrade $http_upgrade;
#     proxy_set_header Connection $connection_upgrade;
#     proxy_set_header Host $host;
#     proxy_set_header X-Real-IP $remote_addr;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
# }
