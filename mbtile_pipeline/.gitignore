# Large binary files — not tracked in git
data/*.mbtiles
data/*.pbf
data/tmp/
data/*.tsv.gz

# Incremental build cache + intermediate GeoJSON (generated at build time)
custom/data/.custom_cache/
custom/data/.custom_tmp/

# Custom GeoJSON overrides (optional, populated by hand)
custom/data/*.geojson
custom/data/*.geojsonl
